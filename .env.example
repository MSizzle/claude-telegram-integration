# Telegram bot credentials for Claude Code integration.
# Either export these as environment variables, or create
# ~/.claude/telegram-config.json with {"token": "...", "chat_id": "..."}
#
# Get a bot token from @BotFather on Telegram.
# Get your chat_id by messaging @userinfobot.

TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-numeric-chat-id-here
